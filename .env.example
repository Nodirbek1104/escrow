# Paylov to'lov tizimi (developer.paylov.uz/subscribe/authorization)
# PAYLOV_MODE: 'mock' | 'live'. mock — demo uchun, Paylov chaqiruvlari soxta-OK
# qaytaradi va audit DB'ga yoziladi. live — real OAuth2 + outbound chaqiruvlar.
PAYLOV_MODE=mock
PAYLOV_BASE_URL
PAYLOV_CONSUMER_KEY
PAYLOV_CONSUMER_SECRET
PAYLOV_USERNAME
PAYLOV_PASSWORD
# Paylov merchant ID (faqat checkout link yaratish uchun, OAuth2 uchun emas)
PAYLOV_MERCHANT_ID
# Paylov callback (webhook) Basic Auth — Paylov merchant kabinetida sozlanadi
PAYLOV_CALLBACK_USERNAME
PAYLOV_CALLBACK_PASSWORD
